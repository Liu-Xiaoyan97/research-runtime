.DS_Store
__pycache__/
*.pyc

.venv/
venv/
.env
.env.*

*.log
*.tmp
*.lock

# Python / uv
.uv-cache/

# Large model artifacts
*.pt
*.pth
*.ckpt
*.safetensors
*.bin

# Runtime: ignore everything by default
runtime/**

# Runtime: keep only contract/state files
!runtime/
!runtime/CLAUDE.md

!runtime/objective/
!runtime/objective/objective.yaml

!runtime/state/
!runtime/state/state.json
!runtime/state/current_iteration.json
!runtime/state/val_loss.json

!runtime/history/
!runtime/history/timeline.json

!runtime/knowledge/
!runtime/knowledge/learned_patterns.md
!runtime/knowledge/rejected_ideas.md

!runtime/debates/
!runtime/debates/.gitkeep
!runtime/debates/*.md

!runtime/experiments/
!runtime/experiments/best.json
!runtime/experiments/*.json

# Still ignore large or noisy experiment files inside runtime
runtime/**/logs/
runtime/**/*.log
runtime/**/*.out
runtime/**/*.err
runtime/**/*.tmp
runtime/**/*.lock
runtime/**/*.pt
runtime/**/*.pth
runtime/**/*.ckpt
runtime/**/*.safetensors
runtime/**/*.bin

# Output is generated and should not be tracked except .gitkeep
output/**
!output/
!output/.gitkeep

.venv/


# Project submodule working tree should not leak generated artifacts into runtime repo.
project/nn-architecture/**
!project/
!project/.gitkeep
project/**/.venv/
project/**/__pycache__/
project/**/*.pyc