# =========================
# System / Python
# =========================
.DS_Store
__pycache__/
*.pyc
.venv/
venv/
.env
.env.*
*.log
*.tmp

# uv cache
.uv-cache/

# codegraph index (local, rebuildable)
.codegraph/

# =========================
# Model artifacts
# =========================
*.pt
*.pth
*.ckpt
*.safetensors
*.bin

# =========================
# Manifest-installed Claude config (source: oh-my-autoresearch)
# The whole .claude/ tree and the root CLAUDE.md are installed by the manifest
# (copy_if_missing) plus the local settings override; do not track them here.
# =========================
/.claude/
/CLAUDE.md

# Operational scripts are manifest-installed from oh-my-autoresearch (scripts/runtime/)
/scripts/

# =========================
# Output (always generated)
# =========================
output/**
!output/.gitkeep

# =========================
# Project workspace (kept locally, never synced to remote)
# =========================
project/**
!project/.gitkeep

# =========================
# Runtime (STRICT RULE MODEL)
# =========================
# Ignore everything in runtime by default, then re-include ONLY the
# deployment-owned contract/state that must be committed:
#   - runtime/objective/objective.yaml
#   - runtime/state/*.json
#   - runtime/knowledge/*.md
#   - runtime/training/entrypoint.yaml
#
# Everything else under runtime/ is NOT tracked, because it is either
# manifest-installable (runtime/CLAUDE.md, runtime/schemas) or a generated
# research artifact (debates, experiments, history, logs).
runtime/**

# ---- objective (user-owned) ----
!runtime/objective/
!runtime/objective/objective.yaml

# ---- state machine ----
!runtime/state/
!runtime/state/state.json
!runtime/state/current_iteration.json
!runtime/state/val_loss.json
runtime/state/*.tmp

# ---- accumulated knowledge ----
!runtime/knowledge/
!runtime/knowledge/learned_patterns.md
!runtime/knowledge/rejected_ideas.md

# ---- training entrypoint (deployment-specific) ----
!runtime/training/
!runtime/training/entrypoint.yaml

# ---- keep the debates directory present (its .md files stay untracked) ----
!runtime/debates/
!runtime/debates/.gitkeep

# NOT tracked (left ignored by the default runtime/** rule):
#   runtime/CLAUDE.md            (manifest-installable)
#   runtime/schemas/             (manifest-installable; source = workflow)
#   runtime/debates/*.md         (generated AgentTeam output)
#   runtime/experiments/         (generated experiment records)
#   runtime/history/             (generated timeline)

# =========================
# runtime noise
# =========================
runtime/**/logs/
runtime/**/*.log
runtime/**/*.out
runtime/**/*.err
runtime/**/*.tmp
runtime/**/*.lock

# =========================
# safety: model artifacts inside runtime/project
# =========================
runtime/**/*.pt
runtime/**/*.pth
runtime/**/*.ckpt
runtime/**/*.safetensors
runtime/**/*.bin


note.txt
CLAUDE-FABLE-5.md